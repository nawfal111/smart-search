{
  "name": "smart-search",
  "displayName": "Smart Search",
  "description": "Advanced workspace search with replace support",
  "version": "1.0.0",
  "publisher": "nawfal",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smart-search.openSearch",
        "title": "Smart Search"
      },
      {
        "command": "smart-search.reindex",
        "title": "Smart Search: Re-index Workspace"
      }
    ],
    "configuration": {
      "title": "Smart Search",
      "properties": {
        "smartSearch.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Base URL of the Smart Search Python backend. Change this to point to a remote server (e.g. https://my-backend.example.com)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
